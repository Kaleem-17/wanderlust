<% layout("/layouts/boilerplate") %>
<h3 class="mt-3">Search Result for <%= searchTerm %></h3>


 <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
  <% for(let listing of allListing){ %>
    <a class="card-link" href="/listing/<%= listing._id %>">
<div class="listing-card col" >
  <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_img" style="height: 20rem;">
 <!-- <div class="card-img-overlay"> </div> -->
  <div class="card-body">
   <b> <p class="card-text"><%= listing.title %></b>
    <br>
&#8360;
<%= listing.price ? listing.price.toLocaleString("en-PK") : "N/A" %> /night
  </p>
  </div>
</div>
</a>
 <% } %>
</div>