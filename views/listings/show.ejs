<% layout("/layouts/boilerplate") %>

<script>
  const mapTilerKey = "<%= mapTilerKey %>";
  const coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;
  const listingTitle = "<%= listing.title %>";
  const listingLocation = "<%= listing.location %>, <%= listing.country %>";
</script>

<div class="row mt-3">

  <!-- Title -->
  <div class="col-6 offset-3">
    <h3><%= listing.title %></h3>
  </div>

  <!-- Listing card -->
  <div class="col-6 offset-3 show-card">
    <div class="listing-card">
      <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_img" style="height: 20rem;">
      <div class="card-body">
        <p class="card-text">Owned by: <%= listing.owner.username %></p>
        <p class="card-text"><%= listing.description %></p>
        <p class="card-text">&#8360; <%= listing.price.toLocaleString("en-PK") %> /night</p>
        <p class="card-text"><%= listing.location %></p>
        <p class="card-text"><%= listing.country %></p>
      </div>
    </div>
  </div>

  <!-- Edit/Delete buttons -->
  <% if(currentUser && currentUser._id.equals(listing.owner._id)){ %>
  <div class="col-6 offset-3 mb-3">
    <div class="btns">
      <a href="/listing/<%=listing._id %>/edit" class="btn edit-btn ">Edit</a>
      <form method="post" action="/listing/<%=listing._id %>/?_method=DELETE">
        <button class="btn btn-danger">Delete</button>
      </form>
    </div>
  </div>
  <% } %>

  <!-- Divider -->
  <div class="col-12"><hr></div>

  <!-- Leave a review -->
  <div class="col-6 offset-3">
    <h4>Leave a review</h4>
    <form action="/listing/<%= listing._id %>/review" method="post" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="rating" class="form-label"><b>Rate</b></label>
        <fieldset class="starability-grow">
          <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
          <input type="radio" id="first-rate1" name="review[rating]" value="1" />
          <label for="first-rate1" title="Terrible">1 star</label>
          <input type="radio" id="first-rate2" name="review[rating]" value="2" />
          <label for="first-rate2" title="Not good">2 stars</label>
          <input type="radio" id="first-rate3" name="review[rating]" value="3" />
          <label for="first-rate3" title="Average">3 stars</label>
          <input type="radio" id="first-rate4" name="review[rating]" value="4" />
          <label for="first-rate4" title="Very good">4 stars</label>
          <input type="radio" id="first-rate5" name="review[rating]" value="5" />
          <label for="first-rate5" title="Amazing">5 stars</label>
        </fieldset>
      </div>
      <div class="mb-3">
        <label for="comment" class="form-label">Comments</label>
        <textarea name="review[comment]" id="comment" class="form-control" required></textarea>
        <div class="invalid-feedback">write comment to submit</div>
      </div>
      <button class="btn btn-dark mt-3 mb-3">Submit</button>
    </form>
  </div>

  <!-- Divider -->
  <div class="col-12"><hr></div>

  <!-- All Reviews -->
  <div class="col-10 offset-2 mb-3">
    <h4>All Reviews</h4>
    <div class="row row-cols-1 row-cols-md-2 g-4">
      <% for(let review of listing.reviews){ %>
      <div class="col">
        <div class="card h-100 shadow-sm">
          <div class="card-body d-flex flex-column">
            <div class="stars mb-2 ms-3">
              <p>@<%= review.author.username %></p>
              <p class="starability-result" data-rating="<%= review.rating %>"></p>
            </div>
            <p class="card-text mt-2 mb-3 ms-3" style="font-size: 1rem; line-height: 1.4;">
              "<%= review.comment %>"
            </p>
            <div class="mt-auto">
              <form action="/listing/<%= listing._id %>/review/<%= review._id %>?_method=DELETE" method="post">
                <button class="btn btn-danger btn-sm ms-3 mb-3">Delete</button>
              </form>
            </div>
          </div>
        </div>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Divider -->
  <div class="col-12"><hr></div>

  <!-- Map -->
  <div class="col-10 offset-2 mt-2 mb-4">
    <h5>Where you'll be</h5>
    <div id="map"></div>
  </div>

</div>  <!-- ✅ single outer row closes here -->